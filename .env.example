# Create a key at https://gonkarouter.io/dashboard
GONKA_API_KEY=

# Optional public browser token for the dark Fact Atlas globe
MAPBOX_PUBLIC_TOKEN=

# Optional public, read-only three-day Signals bundles (one JSON object per UTC date)
SIGNAL_CACHE_BASE_URL=https://last-night-on-earth.oss-cn-hangzhou.aliyuncs.com/fact-atlas/signals

# Optional public Chronicle contract. Private Atlas works without a wallet or contract.
VITE_FACT_ATLAS_CONTRACT_ADDRESS=
VITE_FACT_ATLAS_CHAIN_NAME=Base Sepolia
VITE_FACT_ATLAS_CHAIN_ID=84532
VITE_FACT_ATLAS_RPC_URL=https://sepolia.base.org
VITE_FACT_ATLAS_EXPLORER_URL=https://sepolia-explorer.base.org

# Optional overrides
GONKA_BASE_URL=https://api.gonkarouter.io/v1
KIMI_MODEL=moonshotai/Kimi-K2.6
MINIMAX_MODEL=MiniMaxAI/MiniMax-M2.7
HOST=0.0.0.0
PORT=5173
