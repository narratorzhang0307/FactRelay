<?xml version="1.0"?>
<!DOCTYPE fontconfig SYSTEM "fonts.dtd">
<fontconfig>
  <!-- The bundled headless LibreOffice runtime does not inherit macOS font
       discovery. Point Fontconfig at the system and user font folders so
       generated bilingual PDFs preserve Chinese glyphs. -->
  <dir>/System/Library/Fonts</dir>
  <dir>/System/Library/Fonts/Supplemental</dir>
  <dir>/Library/Fonts</dir>
  <dir>~/Library/Fonts</dir>
  <cachedir>/private/tmp/factatlas-font-cache</cachedir>
</fontconfig>
