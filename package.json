{
  "name": "factrelay",
  "private": false,
  "version": "0.1.0",
  "type": "module",
  "description": "Fact Atlas is a verifiable personal knowledge map powered by FactRelay and GonkaRouter.",
  "scripts": {
    "dev": "node server.mjs",
    "prebuild": "node scripts/clean-dist.mjs",
    "build": "npm run build:client && npm run build:worker && npm run build:hosting",
    "build:client": "vite build",
    "build:worker": "vite build --config vite.worker.config.ts",
    "build:hosting": "node scripts/stage-hosting.mjs",
    "capture:live-demo": "node scripts/capture-live-demo.mjs",
    "signals:oss": "node scripts/build-signal-oss-bundles.mjs",
    "signals:snapshot": "node scripts/build-signal-snapshot.mjs",
    "start": "NODE_ENV=production node server.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "contract:compile": "solcjs --bin --abi contracts/FactAtlasChronicle.sol -o tmp/contracts",
    "contract:deploy:base-sepolia": "node scripts/deploy-chronicle.mjs",
    "verify": "npm run typecheck && npm run test && npm run contract:compile && npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ethers": "^6.15.0",
    "lucide-react": "^0.468.0",
    "mapbox-gl": "^3.24.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "solc": "^0.8.30",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vitest": "^4.1.10"
  }
}
